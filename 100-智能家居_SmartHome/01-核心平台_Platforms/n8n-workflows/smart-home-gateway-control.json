{
  "name": "Smart Home Gateway Control",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "smarthome",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.body.action }}",
              "operation": "equals",
              "value2": "scene"
            }
          ]
        }
      },
      "id": "route-action",
      "name": "Route Action",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [470, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8900/scenes/{{ $json.body.scene_id }}/activate",
        "options": {}
      },
      "id": "activate-scene",
      "name": "Activate Scene",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [690, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8900/devices/{{ $json.body.entity_id }}/control",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "action",
              "value": "={{ $json.body.action }}"
            }
          ]
        },
        "options": {}
      },
      "id": "control-device",
      "name": "Control Device",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [690, 400]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, result: $json }) }}"
      },
      "id": "respond",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [910, 300]
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [
        [{ "node": "Route Action", "type": "main", "index": 0 }]
      ]
    },
    "Route Action": {
      "main": [
        [{ "node": "Activate Scene", "type": "main", "index": 0 }],
        [{ "node": "Control Device", "type": "main", "index": 0 }]
      ]
    },
    "Activate Scene": {
      "main": [
        [{ "node": "Respond", "type": "main", "index": 0 }]
      ]
    },
    "Control Device": {
      "main": [
        [{ "node": "Respond", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": { "executionOrder": "v1" },
  "meta": {
    "description": "通过 Webhook 触发智能家居控制。POST /webhook/smarthome {action:'toggle', entity_id:'switch.xxx'} 或 {action:'scene', scene_id:'scene.sleep_mode'}"
  }
}
