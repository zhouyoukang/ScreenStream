# ScreenStream Relay Server Configuration

# Server port (Nginx will reverse proxy to this)
PORT=9100

# Optional: TURN server for NAT traversal (coturn)
# Without TURN, ~80% of connections work via STUN only.
# With TURN, ~99% of connections work (including restrictive NATs).
# TURN_SERVER=turn:turn.aiotvr.xyz:3478
# TURN_SECRET=your_coturn_shared_secret
