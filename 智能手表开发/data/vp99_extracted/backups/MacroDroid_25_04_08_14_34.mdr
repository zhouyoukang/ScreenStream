GET\u003d$((7 - CURRENT_DAY + TARGET_DAY_NUM))\nfi\n\n# Get the current date components\nCURRENT_YEAR\u003d$(date +%Y)\nCURRENT_MONTH\u003d$(date +%m)\nCURRENT_DAY_OF_MONTH\u003d$(date +%d)\n\n# Calculate the next target date\nNEXT_TARGET_DAY\u003d$((CURRENT_DAY_OF_MONTH + DAYS_UNTIL_TARGET))\n\n# Check if we need to adjust the month and year\nif [ \"$NEXT_TARGET_DAY\" -gt 31 ]; then\n    NEXT_TARGET_DAY\u003d$((NEXT_TARGET_DAY - 31))\n    CURRENT_MONTH\u003d$((CURRENT_MONTH + 1))\nfi\n\n# Handle month overflow\nif [ \"$CURRENT_MONTH\" -gt 12 ]; then\n    CURRENT_MONTH\u003d1\n    CURRENT_YEAR\u003d$((CURRENT_YEAR + 1))\nfi\n\n# Format the next target date\nNEXT_TARGET_DATE\u003d$(printf \"%04d-%02d-%02d\" \"$CURRENT_YEAR\" \"$CURRENT_MONTH\" \"$NEXT_TARGET_DAY\")\n\n# Combine the target date with the target time\nNEXT_TARGET\u003d\"$NEXT_TARGET_DATE $TARGET_TIME\"\n\n# Convert the next target time to seconds since epoch\nNEXT_TARGET_TIMESTAMP\u003d$(date -d \"$NEXT_TARGET\" +%s 2\u003e/dev/null)\n\n# If the above command fails, we need to handle it\nif [ $? -ne 0 ]; then\n    echo \"Error calculating the next target timestamp.\"\n    exit 1\nfi\n\n# Calculate the difference in seconds\nDIFFERENCE\u003d$((NEXT_TARGET_TIMESTAMP - CURRENT_TIME))\n\n# Output the result in minutes\nif [ $DIFFERENCE -lt 0 ]; then\n    echo \"The specified time has already passed.\"\nelse\n    MINUTES\u003d$((DIFFERENCE))\n    echo \"$MINUTES\"\nfi\n","m_variableToSaveResponse":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"secondsToEvent","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},"timeoutSeconds":30,"useHelper":false,"useShizuku":false,"disableLogging":false,"m_SIGUID":-6660253852438000360,"m_classType":"ShellScriptAction","m_comment":"get secs until next \"day\"","m_constraintList":[],"m