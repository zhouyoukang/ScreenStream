alse,"m_newBooleanValue":false,"m_newDoubleValue":0.0,"m_newIntValue":0,"m_newStringValue":"{year}-{month_digit}-{dayofmonth} {hour_0}:{minute}","m_trueLabel":"True","m_userPrompt":false,"m_userPromptEmptyAtStart":false,"m_userPromptPassword":false,"m_userPromptShowCancel":true,"m_userPromptStopAfterCancel":true,"m_variable":{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"currentTime","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-7506813466922771037,"m_classType":"SetVariableAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"blockNextAction":true,"m_nonRoot":true,"m_script":"#!/bin/bash\n\n# Define the start and end times in a compatible format\nstart_time\u003d\"{lv\u003dcurrentTime}\"  # Example: December 25, 2024, at 2:30 PM\nend_time\u003d\"{lv\u003dalarmTime}\"    # Example: December 26, 2024, at 9:15 AM\n\n# Convert the start time to total minutes\nstart_year\u003d$(echo $start_time | cut -d\u0027-\u0027 -f1)\nstart_month\u003d$(echo $start_time | cut -d\u0027-\u0027 -f2)\nstart_day\u003d$(echo $start_time | cut -d\u0027-\u0027 -f3 | cut -d\u0027 \u0027 -f1)\nstart_hour\u003d$(echo $start_time | cut -d\u0027 \u0027 -f2 | cut -d\u0027:\u0027 -f1)\nstart_minute\u003d$(echo $start_time | cut -d\u0027:\u0027 -f2)\n\n# Convert the end time to total minutes\nend_year\u003d$(echo $end_time | cut -d\u0027-\u0027 -f1)\nend_month\u003d$(echo $end_time | cut -d\u0027-\u0027 -f2)\nend_day\u003d$(echo $end_time | cut -d\u0027-\u0027 -f3 | cut -d\u0027 \u0027 -f1)\nend_hour\u003d$(echo $end_time | cut -d\u0027 \u0027 -f2 | cut -d\u0027:\u0027 -f1)\nend_minute\u003d$(echo $end_time | cut -d\u0027:\u0027 -f2)\n\n# Function to calculate total minutes from a reference date\ntotal_minutes() {\n    year\u003d$1\n    month\u003d$2\n    day\u003d$3\n    hour\u003d$4\n    minute\u003d$5\n\n    # Calculate total minutes since a reference point (e.g., 1970-01-01)\n    total\u003d$(( (year - 1970) * 525600 + (month - 1) * 43800 + (day - 1) * 1440 + hour * 60 + minute ))\n    echo $total\n}\n\n# Calculate total minutes for start and end times\nstart_total\u003d$(total_minutes $start_year $start_month $start_day $start_hour $start_minute)\nend_total\u003d$(total_minutes $end_year $end_month $end_day $end_hour $end_minute)\n\n# Calculate the difference in minutes\ndiff_minutes\u003d$((end_total - start_total))\n\n# Output the result\necho \"$diff_minutes\"\n","m_variableToSaveResponse":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"minsToAlarm","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},"timeoutSeconds":30,"useHelper":false,"useShizuku":false,"disableLogging":false,"m_SIGUID":-8076230156981590503,"m_classType":"ShellScriptAction","m_comment":"get minute between 2 times on different dates alt","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"booleanDictionaryKeys":{"keys":[]},"dictionaryKeys":[],"dictionaryOrArrayType":-1,"existingManualKeyType":0,"m_booleanInvert":false,"m_darkMode":-1,"m_doubleRandomMax":0.0,"m_doubleRandomMin":0.0,"m_expression":"{strval\u003dminsToAlarm}","m_falseLabel":"False","m_intExpression":true,"m_intRandom":false,"m_intRandomMax":0,"m_intRandomMin":0,"m_intValueDecrement":false,"m_intValueIncrement":false,"m_newBooleanValue":false,"m_newDoubleValue":0.0,"m_newIntValue":0,"m_newStringValue":"{month}","m_trueLabel":"True","m_userPrompt":false,"m_userPromptEmptyAtStart":false,"m_userPromptPassword":false,"m_userPromptShowCancel":true,"m_userPromptStopAfterCancel":true,"m_variable":{"description":"","dictionary":{"entries":[],"isArray"