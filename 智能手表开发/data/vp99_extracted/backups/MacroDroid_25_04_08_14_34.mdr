ableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":true,"isSecure":true,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"videoPath","m_stringValue":"","m_type":2,"supportsInput":true,"supportsOutput":true},{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"smsMessage","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"macroName","m_stringValue":"🗣 Macrodroid voice assistant (R2D2) ©️","m_type":2,"supportsInput":false,"supportsOutput":true},{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"msgConfirmation","m_stringValue":"","m_type":0,"supportsInput":false,"supportsOutput":true},{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"toggleSettings","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"siteToSearch","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"chatObject","m_stringValue":"","m_type":4,"supportsInput":false,"supportsOutput":true},{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"chatResponse","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"newChat","m_stringValue":"True","m_type":2,"supportsInput":false,"supportsOutput":true},{"dictionary":{"entries":[{"key":"- Get current weather update:\n\n\"What\u0027s the weather\"","variable":{"textValue":"This will gather recent weather data from Open-Meteo on your last known location. It will get the current conditions aswell as a 7 day forcast.\n\nSay:\n\n\"What\u0027s the weather\"\n\nExample:\n\n\"What\u0027s the weather today\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- List commands:\n\n\"List commands\"","variable":{"textValue":"This command will list all available commands and info about each command. This command is recognized when the input starts with the word \"list\" and ends with the word \"commands\".\n\nSay:\n\n\"List commands\"\n\nor\n\n\"List all commands\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Search a song:\n\n\"What song is this?\"","variable":{"textValue":"This command will use Google song search to find what song is playing (like Shazam) and tell you what song is playing.\n\nSay:\n\n\"What song is this?\"\n\nor \n\n\"What song is playing?\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Cancel:\n\n\"Cancel\"","variable":{"textValue":"This command will cancel the macro. It is recognized when any voice input is ended with the word \"Cancel\".\n\nSay:\n\n\"Cancel\"\n\nExample:\n\n\"Call mom cancel\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Get directions to location:\n\n\"Get directions to \u0027location\u0027 \"","variable":{"textValue":"This command will open Google maps and give you directions to a specified address or any labeled saved location you have saved in Google maps. This command is recognized when...\n\nSay:\n\n\"Get directions to \u0027location name\u0027 \"\n\nExample:\n\n\"Get directions to walmart\"\n\nor\n\n\"Get directions to \u0027saved location name\u0027 \"\n\nExample:\n\n\"Get directions to Johnny\u0027s house.\"\n\nor\n\n\"Get directions to \u0027address\u0027 \"\n\nExample:\n\n\"Get directions to 123 Main Street.\"\n","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Open application:\n\n\"Open app \u0027app name\u0027 \"","variable":{"textValue":"This command will open any app by name. This command is recognized when any voice input begins with the words \"open app\".\n\nSay:\n\n\"Open app \u0027app name\u0027 \"\n\nExample:\n\n\"Open app YouTube.\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Open setting:\n\n\"Open setting \u0027setting to open\u0027 \"","variable":{"textValue":"This command will open the settings app and perform a search of any setting. This command is recognized when any voice input begins with the words \"open setting\" or \"open settings\" Note, the setting name must be EXACT.\n\nSay:\n\n\"Open setting \u0027setting to open\u0027 \"\n\nExample:\n\n\"Open setting developer options\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Play a song:\n\n\"Play song \u0027song name\u0027 \"","variable":{"textValue":"This command will play songs by name that you have stored on your device.\n\nSay:\n\n\"Play song \u0027song name\u0027 \"\n\nExample:\n\n\"Play song Houdini.\"\n","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Run a macro:\n\n\"Run macro \u0027macro name\u0027 \"","variable":{"textValue":"This macro will run macros you have on your device by macro.\n\nSay:\n\n\"Run macro \u0027macro name\u0027 \"\n\nor\n\n\"Run program \u0027macro name\u0027 \"\nExample:\n\n\"Run macro Infinite clipboard\".","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Search any website:\n\n\"Search \u0027websiteName.com\u0027 for \u0027search query\u0027 \"","variable":{"textValue":"This command will search any website. This command is recognized when any voice input begins with the word \"search\" and also contain a \".com\", \".net\", or \".org\".\n\nSay:\n\n\"Search \u0027websiteName.com\u0027 for \u0027search query\u0027 \"\n\nor\n\n\"Search \u0027websiteName.net\u0027 for \u0027search query\u0027 \"\n\nor\n\n\"Search \u0027websiteName.org\u0027 for \u0027search query\u0027 \"\n\nExample:\n\n\"Search youtube.com for funny cats.\"\n\nor\n\n\"Search Amazon.com for galaxy phones.\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Set a calendar event:\n\n\"Set an event on \u0027event date and time\u0027 \"","variable":{"textValue":"This command will set a calendar event on a specified date and time.\n\nSay:\n\n\"Set an event on \u0027event date and time\u0027 \"\n\nor\n\n\"Set an event on \u0027event date and time\u0027 titled \u0027example title\u0027  \"\n\nExample:\n\n\"Set an event on Sunday at 2130\"\n\nor\n\n\"Set an event for tomorrow at 9:30am titled John\u0027s birthday. \"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Set a timer:\n\n\"Set a timer for \u0027# hours and/or # minutes and/or # seconds\u0027 \"","variable":{"textValue":"This command will start a timer  for a specified time.\n\nSay:\n\n\"Set a timer for \u0027# hours and/or # minutes and/or # seconds\u0027 \"\n\nExample:\n\n\"Set a timer for 30 seconds\"\n\nor\n\n\"Set a timer for a minute\"\n\nor \n\n\"Set a time for 1 hour 30 minutes and 30 seconds\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Set an alarm:\n\n\"Set an alarm for \u0027alarm day and/or time\"","variable":{"textValue":"This command will set an alarm at a specified day and time. This command can only set an alarm one week into the future. if you set a date more than a week away, it well set a calendar event instead.\n\n\nSay:\n\n\"Set an alarm for \u0027alarm day and/or time\"\n\nExample:\n\n\"Set an alarm on Sunday at 2130.\"\n\nor \n\n\"Set an alarm for the 22nd at 8:30 pm\"\n\nor\n\n\"Set an alarm for 8:30.\"\n\nor \n\n\"Set an alarm for tomorrow at 8:30am.\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Analyze clipboard text: \n\n\"Clipboard text\"","variable":{"textValue":"This command will substitute the words \"clipboard text\" with the text in you Clipboard. It is intended to be used in tandem with other commands. \n\nSay:\n\n\"Clipboard text\"\n\nExample:\n\n\"Search google.com for clipboard text.\"\n\nor\n\n\"Fix errors in clipboard text.\"\n\n","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Call mobile number:\n\n\"Call \u0027contact name\u0027 \"","variable":{"textValue":"This command recognizes the keyword Call if its the first word of the command. In case the input contains a phone number, it will just call the phone number you input. In case you input a contact name, it will search for the contacts mobile phone number and call thay number.\n\nSay:\n\n\"Call \u0027contact name\u0027 \"\n\nExample:\n\n\"Call mom\"\n\nor\n\n\"Call \u0027phone number\u0027 \"\n\nExample:\n\n\"Call 1234568690\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Make new note:\n\n\"Make a note to \u0027note\u0027 \"","variable":{"textValue":"This command will make a new note Google Note Keep app. This command is recognized when any voice input begins with the words \"make note\" or \"make a note\".\n\nSay:\n\n\"Make a note to \u0027note\u0027 \"\n\nor\n\n\"Make note \u0027note\u0027 \"\n\nExample:\n\n\"Make a note to get eggs\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Open website:\n\n\"Open \u0027websiteName.com\u0027 \"","variable":{"textValue":"This command will open any website by name. This command is recognized if the input begins with the word \"open\" and ends with a \".com\", \".net\", or \".org\"\n\nSay:\n\n\"Open \u0027websiteName.com\u0027 \"\n\n or\n\n\"Open \u0027websiteName.net\u0027 \"\n\nor\n\n\"Open \u0027websiteName .org\u0027 \"\n\nExample:\n\n\"Open youtube.com\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Play a movie:\n\n\"Play movie \u0027movie name\u0027 \"","variable":{"textValue":"This command will play movies by name that you have stored on your device. This function will search a specified folder for video files by name. This function will find the file with the name of the closest match to the name given in the input.\n\nSay:\n\n\"Play movie \u0027movie name\u0027 \"\n\nExample:\n\n\"Play movie Inception.\"\n\nExample output:\n\nThe file named Inception.mp4 will play  ","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Send a text message:\n\n\"Send text to \u0027contact name\u0027 \"","variable":{"textValue":"This command will send a text message to any phone number or contact name.\n\nSay:\n\n\"Send text to \u0027contact name\u0027 \"\n\nor\n\n\"Send a message to \u0027phone number\u0027 \"\n\nor \n\n\"Send sms to \u0027contact name\u0027 \"\n\nExample:\n\n\"Send a text to mom\"\n\nor\n\n\"Send message to 1234567890\"\n","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Send an email:\n\n\"Send email to \u0027contact name\u0027 \"","variable":{"textValue":"This command will send an email to an email address or a contact\u0027s email.\n\n\nSay:\n\n\"Send email to \u0027contact name\u0027 \"\n\nor\n\n\"Send email to \u0027email address\u0027 \"\n\nor\n\n\"Send email to \u0027contact name\u0027 titled \u0027example title\u0027 \"\n\nor\n\n\"Send email to \u0027contact name\u0027 subject \u0027subject name\u0027 \"\n\nExample:\n\n\"Send email to John Smith titled Fishing trip\"\n","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"Image Search:\n\n\"Search for pictures of \u0027search content\u0027 \"","variable":{"textValue":"This command will perform a DuckDuckGo image search\n\nSay:\n\n\"Search for pictures of \u0027search content\u0027 \"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"AI Query:\n\nAsk any question","variable":{"textValue":"If the command is not recognized it will perform an AI query.","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Set the volume of the voice assistant:\n\n\"Set your volume to \u0027volume\u0027 \"","variable":{"textValue":"This command will set the volume of the voice assistant.\n\nSay:\n\n- \"Set your volume to \u0027volume\u0027 \"\n\nExample:\n\n\"Set your volume to 30\"\nor\n\"Set your volume to 50%\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Search news headlines:\n\n\"Search news for \u0027keywords\u0027 \"","variable":{"textValue":"This command will search today\u0027s stories for specified keywords. Im case of multiple keywords, the search will search stories that each word separately.\n\nSay:\n\n\"Search news for \u0027keywords\u0027 \"\n\nExample:\n\n\"Search news for Elon Musk\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Open folder\n\n\"Open folder \u0027folder name\u0027 \"","variable":{"textValue":"This command will open any folder on your device. it is set search 5 layers deep for the specified folder but this can be adjusted in the action block via the \"maxDepth\" variable. \"Android\" folders will be excluded.\n\nSay:\n\n\"Open folder \u0027folder name\u0027 \"\n\nExample:\n\n\"Open folder Download\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"- Get news updates\n\n\"Get news update\"","variable":{"textValue":"This command will get you news updates\n\nSay:\n\n\"Get news update\"\n\nor\n\n\"What\u0027s the news\"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"}],"isArray":false,"parents":[],"variableType":4,"parentKeys":[],"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"commandDic","m_stringValue":"","m_type":4,"supportsInput":false,"supportsOutput":true},{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":true,"m_decimalValue":0.0,"m_intValue":0,"m_name":"voiceOnScreen","m_stringValue":"","m_type":0,"supportsInput":false,"supportsOutput":true},{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"voiceInputFailed","m_stringValue":"","m_type":0,"supportsInput":false,"supportsOutput":true},{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":