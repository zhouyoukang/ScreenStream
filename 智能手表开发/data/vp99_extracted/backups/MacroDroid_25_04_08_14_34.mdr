,"m_isOrCondition":false},{"booleanDictionaryKeys":{"keys":[]},"dictionaryKeys":[],"dictionaryOrArrayType":-1,"existingManualKeyType":0,"m_booleanInvert":false,"m_darkMode":-1,"m_doubleRandomMax":0.0,"m_doubleRandomMin":0.0,"m_falseLabel":"False","m_intExpression":false,"m_intRandom":false,"m_intRandomMax":0,"m_intRandomMin":0,"m_intValueDecrement":false,"m_intValueIncrement":false,"m_newBooleanValue":false,"m_newDoubleValue":0.0,"m_newIntValue":0,"m_newStringValue":"{dayofweek}","m_trueLabel":"True","m_userPrompt":false,"m_userPromptEmptyAtStart":false,"m_userPromptPassword":false,"m_userPromptShowCancel":true,"m_userPromptStopAfterCancel":true,"m_variable":{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"day","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-5334363150681148844,"m_classType":"SetVariableAction","m_comment":"if day is not given","m_constraintList":[{"checkCase":false,"dictionaryKeys":{"keys":[]},"dictionaryType":2,"enableRegex":false,"m_booleanValue":false,"m_doubleValue":0.0,"m_intCompareVariable":false,"m_intGreaterThan":false,"m_intLessThan":false,"m_intNotEqual":false,"m_intValue":0,"m_otherValueToCompare":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"alarmOutput","m_stringValue":"","m_type":1,"supportsInput":true,"supportsOutput":true},"m_stringComparisonType":0,"m_stringEqual":true,"m_stringValue":"","m_variable":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"day","m_stringValue":"","m_type":2,"supportsInput":true,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-8662939404278019220,"m_classType":"MacroDroidVariableConstraint","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_isDisabled":false,"m_isOrCondition":false},{"blockNextAction":true,"m_nonRoot":true,"m_script":"#!/bin/sh\n\n# Specify the target day and time\nTARGET_DAY\u003d\"{lv\u003dday}\"  # Change this to your desired day\nTARGET_TIME\u003d\"{lv\u003dtime}\"  # Change this to your desired time\n\n# Get the current date and time\nCURRENT_TIME\u003d$(date +%s)\n\n# Get the current day of the week (1\u003dMonday, ..., 7\u003dSunday)\nCURRENT_DAY\u003d$(date +%u)\n\n# Map the target day to a number (1\u003dMonday, ..., 7\u003dSunday)\ncase $TARGET_DAY in\n    Sunday)    TARGET_DAY_NUM\u003d7 ;;\n    Monday)    TARGET_DAY_NUM\u003d1 ;;\n    Tuesday)   TARGET_DAY_NUM\u003d2 ;;\n    Wednesday) TARGET_DAY_NUM\u003d3 ;;\n    Thursday)  TARGET_DAY_NUM\u003d4 ;;\n    Friday)    TARGET_DAY_NUM\u003d5 ;;\n    Saturday)  TARGET_DAY_NUM\u003d6 ;;\n    *)         echo \"Invalid day specified\"; exit 1 ;;\nesac\n\n# Calculate the number of days until the next target day\nif [ \"$CURRENT_DAY\" -le \"$TARGET_DAY_NUM\" ]; then\n    DAYS_UNTIL_TARGET\u003d$((TARGET_DAY_NUM - CURRENT_DAY))\nelse\n    DAYS_UNTIL_TARGET\u003d$((7 - CURRENT_DAY + TARGET_DAY_NUM))\nfi\n\n# Get the current date components\nCURRENT_YEAR\u003d$(date +%Y)\nCURRENT_MONTH\u003d$(date +%m)\nCURRENT_DAY_OF_MONTH\u003d$(date +%d)\n\n# Calculate the next target date\nNEXT_TARGET_DAY\u003d$((CURRENT_DAY_OF_MONTH + DAYS_UNTIL_TARGET))\n\n# Check if we need to adjust the month and year\nif [ \"$NEXT_TARGET_DAY\" -gt 31 ]; then\n    NEXT_TARGET_DAY\u003d$((NEXT_TARGET_DAY - 31))\n    CURRENT_MONTH\u003d$((CURRENT_MONTH + 1))\nfi\n\n# Handle month overflow\nif [ \"$CURRENT_MONTH\" -gt 12 ]; then\n    CURRENT_MONTH\u003d1\n    CURRENT_YEAR\u003d$((CURRENT_YEAR + 1))\nfi\n\n# Handle month-end days\nif [ \"$CURRENT_MONTH\" -eq 2 ]; then\n    if [ $((CURRENT_YEAR % 4)) -eq 0 ] \u0026\u0026 { [ $((CURRENT_YEAR % 100)) -ne 0 ] || [ $((CURRENT_YEAR % 400)) -eq 0 ]; }; then\n        MAX_DAYS\u003d29  # Leap year\n    else\n        MAX_DAYS\u003d28\n    fi\nelif [ \"$CURRENT_MONTH\" -eq 4 ] || [ \"$CURRENT_MONTH\" -eq 6 ] || [ \"$CURRENT_MONTH\" -eq 9 ] || [ \"$CURRENT_MONTH\" -eq 11 ]; then\n    MAX_DAYS\u003d30\nelse\n    MAX_DAYS\u003d31\nfi\n\n# Adjust for month-end\nif [ \"$NEXT_TARGET_DAY\" -gt \"$MAX_DAYS\" ]; then\n    NEXT_TARGET_DAY\u003d$((NEXT_TARGET_DAY - MAX_DAYS))\n    CURRENT_MONTH\u003d$((CURRENT_MONTH + 1))\nfi\n\n# Handle month overflow again\nif [ \"$CURRENT_MONTH\" -gt 12 ]; then\n    CURRENT_MONTH\u003d1\n    CURRENT_YEAR\u003d$((CURRENT_YEAR + 1))\nfi\n\n# Format the next target date\nNEXT_TARGET_DATE\u003d$(printf \"%04d-%02d-%02d\" \"$CURRENT_YEAR\" \"$CURRENT_MONTH\" \"$NEXT_TARGET_DAY\")\n\n# Combine the target date with the target time\nNEXT_TARGET\u003d\"$NEXT_TARGET_DATE $TARGET_TIME\"\n\n\n# Manually calculate the target timestamp\nTARGET_YEAR\u003d$(echo \"$NEXT_TARGET\" | cut -d\u0027-\u0027 -f1)\nTARGET_MONTH\u003d$(echo \"$NEXT_TARGET\" | cut -d\u0027-\u0027 -f2)\nTARGET_DAY\u003d$(echo \"$NEXT_TARGET\" | cut -d\u0027-\u0027 -f3 | cut -d\u0027 \u0027 -f1)\nTARGET_HOUR\u003d$(echo \"$TARGET_TIME\" | cut -d\u0027:\u0027 -f1)\nTARGET_MINUTE\u003d$(echo \"$TARGET_TIME\" | cut -d\u0027:\u0027 -f2)\n\n# Calculate the target timestamp manually\nTARGET_TIMESTAMP\u003d$(date -d \"$TARGET_YEAR-$TARGET_MONTH-$TARGET_DAY $TARGET_HOUR:$TARGET_MINUTE\" +%s 2\u003e/dev/null)\n\n# If the above command fails, we need to calculate it manually\nif [ $? -ne 0 ]; then\n    # Calculate the timestamp manually\n    CURRENT_TIMESTAMP\u003d$(date +%s)\n    SECONDS_IN_A_DAY\u003d86400\n\n    # Calculate the number of days until the next target day\n    if [ \"$CURRENT_DAY\" -le \"$TARGET_DAY_NUM\" ]; then\n        DAYS_UNTIL_TARGET\u003d$((TARGET_DAY_NUM - CURRENT_DAY))\n    else\n        DAYS_UNTIL_TARGET\u003d$((7 - CURRENT_DAY + TARGET_DAY_NUM))\n    fi\n\n    # Calculate the target timestamp\n    TARGET_TIMESTAMP\u003d$((CURRENT_TIMESTAMP + (DAYS_UNTIL_TARGET * SECONDS_IN_A_DAY)))\n\n    # Add the target time to the target timestamp\n    TARGET_TIMESTAMP\u003d$((TARGET_TIMESTAMP + (TARGET_HOUR * 3600) + (TARGET_MINUTE * 60)))\nfi\n\n\n# Calculate the current timestamp\nCURRENT_TIMESTAMP\u003d$(date +%s)\n\n# Calculate the difference in seconds\nDIFFERENCE\u003d$((TARGET_TIMESTAMP - CURRENT_TIMESTAMP))\n\n# Check if the target time is in the future\nif [ \"$DIFFERENCE\" -gt 0 ]; then\n    # Convert seconds to minutes\n    MINUTES_UNTIL_TARGET\u003d$((DIFFERENCE / 60))\n    echo \"$MINUTES_UNTIL_TARGET\"\nelse\n    echo \"The target time has already passed.\"\nfi\n\n\n\n","m_variableToSaveResponse":{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"minsToAlarm","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},"timeoutSeconds":30,"useHelper":false,"useShizuku":false,"disableLogging":false,"m_SIGUID":-6662859885836166646,"m_classType":"ShellScriptAction","m_comment":"get mins until next \"day\" alt","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"booleanDictionaryKeys":{"keys":[]},"dictionaryKeys":[],"dictionaryOrArrayType":-1,"existingManualKeyType":0,"m_booleanInvert":false,"m_darkMode":-1,"m_doubleRandomMax":0.0,"m_doubleRandomMin":0.0,"m_expression":"{strval\u003dminsToAlarm}+1","m_falseLabel":"False","m_intExpression":true,"m_intRandom":false,"m_intRandomMax":0,"m_intRandomMin":0,"m_intValueDecrement":false,"m_intValueIncrement":false,"m_newBooleanValue":false,"m_newDoubleValue":0.0,"m_newIntValue":0,"m_newStringValue":"{month}","m_trueLabel":"True","m_userPrompt":false,"m_userProm