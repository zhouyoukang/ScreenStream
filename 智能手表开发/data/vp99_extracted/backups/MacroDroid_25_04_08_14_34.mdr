       return\n    fi\n\n    # Remove periods from the input and convert to lowercase\n    input_time\u003d$(echo \"$input_time\" | tr -d \u0027.\u0027 | tr \u0027[:upper:]\u0027 \u0027[:lower:]\u0027)\n\n    \n    # Extract the hour, minute, and period (AM/PM)\n    hour\u003d$(echo \"$input_time\" | awk \u0027{print $1}\u0027 | cut -d\u0027:\u0027 -f1)\n    minute\u003d$(echo \"$input_time\" | awk \u0027{print $1}\u0027 | cut -d\u0027:\u0027 -f2)\n    period\u003d$(echo \"$input_time\" | awk \u0027{print $2}\u0027)\n\n   \n\n    # Convert hour to 24-hour format\n    if [ \"$period\" \u003d \"pm\" ] \u0026\u0026 [ \"$hour\" -ne 12 ]; then\n        hour\u003d$((hour + 12))\n    elif [ \"$period\" \u003d \"am\" ] \u0026\u0026 [ \"$hour\" -eq 12 ]; then\n        hour\u003d0\n    fi\n\n    # Format the output to ensure two digits for hour\n    printf \"%02d:%02d\\n\" \"$hour\" \"$minute\"\n}\n\n# Example usage\n\n\nconverted_time\u003d$(convert_to_24_hour \"$time_12hr\")\necho \"$converted_time\"\n","m_variableToSaveResponse":{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"time","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},"timeoutSeconds":30,"useHelper":false,"useShizuku":false,"disableLogging":false,"m_SIGUID":-5542125152554100347,"m_classType":"ShellScriptAction","m_comment":"convert 12 hr to 24 hr format","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"dontLogIfConditionIsFalse":false,"disableLogging":false,"m_SIGUID":-7165106750574226979,"m_classType":"ElseAction","m_comment":"0:00 format","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_option":2,"m_text":"{lv\u003dinput}","m_textManipulation":{"type":"ExtractTextManipulation","params":["\\b([0-9]):([0-5][0-9])\\b","0"]},"variableName":"time","disableLoggin