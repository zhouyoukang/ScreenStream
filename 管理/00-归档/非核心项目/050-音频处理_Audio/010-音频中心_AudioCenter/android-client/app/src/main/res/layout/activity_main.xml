<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Audio Center"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>
            
        <TextView
            android:id="@+id/tvIpAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IP: 192.168.x.x"
            android:textColor="#666666"
            android:layout_marginBottom="32dp"/>

        <!-- SOURCE CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="24dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODE: SOURCE (SEND)"
                    android:textStyle="bold"
                    android:textColor="#2196F3"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Broadcast audio to network."
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>
                    
                <RadioGroup
                    android:id="@+id/rgAudioSource"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    
                    <RadioButton
                        android:id="@+id/rbMic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Microphone"
                        android:checked="true"
                        android:layout_marginEnd="16dp"/>
                        
                    <RadioButton
                        android:id="@+id/rbSystem"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System Audio"
                        android:enabled="false"/> 
                </RadioGroup>

                <Button
                    android:id="@+id/btnSourceStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Start Broadcasting"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- RECEIVER CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODE: RECEIVER (LISTEN)"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Target IP Address"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTargetIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number|textUri"
                        android:text="192.168.1."/>
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/btnReceiverStart"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Listen"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnReceiverStop"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Stop"
                        android:backgroundTint="#FF5252"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Web Dashboard available at http://<DeviceIP>:8085/dashboard"
            android:textAlignment="center"
            android:textSize="12sp"
            android:textColor="#999"/>

    </LinearLayout>
</ScrollView>
