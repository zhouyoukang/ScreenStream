# Smart Home Gateway Configuration
# Copy to .env and fill in your values

# Home Assistant
HA_URL=http://192.168.31.228:8123
HA_TOKEN=your_long_lived_access_token_here

# Gateway
GATEWAY_MODE=direct
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8900

# MiCloud (for direct mode)
HA_CONFIG_PATH=E:\HassWP\config

# Tuya (optional)
TUYA_CLIENT_ID=
TUYA_SECRET=
TUYA_REGION=cn
