{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx.cmd",
      "args": ["-y", "chrome-devtools-mcp@latest", "--isolated"],
      "disabled": false
    },
    "context7": {
      "command": "npx.cmd",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "disabled": false
    },
    "fetch": {
      "command": "npx.cmd",
      "args": ["-y", "fetch-mcp"],
      "disabled": true
    },
    "github": {
      "command": "npx.cmd",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "disabled": false,
      "env": {
        "NODE_OPTIONS": "--require C:/temp/github-proxy-bootstrap.js",
        "HTTPS_PROXY": "http://127.0.0.1:7890",
        "HTTP_PROXY": "http://127.0.0.1:7890"
      }
    },
    "playwright": {
      "command": "npx.cmd",
      "args": ["-y", "@playwright/mcp@latest", "--headless", "--isolated", "--browser", "chromium"],
      "disabled": false,
      "env": {
        "HTTPS_PROXY": "http://127.0.0.1:7890",
        "HTTP_PROXY": "http://127.0.0.1:7890"
      }
    }
  }
}