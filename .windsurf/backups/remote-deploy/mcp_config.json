{
  "mcpServers": {
    "chrome-devtools": {
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated"
      ],
      "command": "npx",
      "disabled": false
    },
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "command": "npx",
      "disabled": false
    },
    "github": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "command": "npx",
      "disabled": false
    },
    "fetch": {
      "args": [
        "-y",
        "fetch-mcp"
      ],
      "command": "npx",
      "disabled": true
    },
    "playwright": {
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless",
        "--isolated"
      ],
      "command": "npx",
      "disabled": false
    }
  }
}
