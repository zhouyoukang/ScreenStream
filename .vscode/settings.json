{
    "workbench.editorAssociations": {
        "*.md": "default"
    },
    "markdown-editor.isDefault": false,
    "markdown.preview.fontSize": 15,
    "markdown.preview.lineHeight": 1.8,
    "markdown.preview.scrollEditorWithPreview": true,
    "markdown.preview.scrollPreviewWithEditor": true,
    "markdown.styles": [
        ".vscode/markdown-preview.css"
    ],
    "files.exclude": {
        ".github": true,
        ".kotlin": true,
        ".venv": true,
        ".gradle": true,
        ".vscode": true,
        ".windsurf": true,
        ".git": true,
        "gradle": true,
        "gradlew": true,
        "gradlew.bat": true,
        "build.gradle.kts": true,
        "settings.gradle.kts": true,
        "gradle.properties": true,
        ".aiexclude": true,
        ".gitignore": true,
        ".windsurfrules": true,
        "LICENSE": true,
        "PrivacyPolicy.md": true,
        "TermsConditions.md": true
    }
}
